// schema.prisma

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ==========================================
// 1. User
// ==========================================
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String?
  nickname  String?
  gender    Gender?

  provider  AuthProvider @default(LOCAL)
  googleId  String?      @unique
  avatarUrl String?

  closetItems   ClosetItem[]
  styleRefs     StyleReference[]
  outfits       Outfit[]
  externalItems ExternalItem[]   // ← WishlistItem에서 교체

  location  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 2. ClothingItem (AI 분석 임시 테이블)
// ==========================================
model ClothingItem {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  jobId       String?  @map("job_id")

  label       String
  label_id    Int

  sourceS3Key String?  @map("source_s3_key")
  cropS3Key   String?  @map("crop_s3_key")
  bbox        Json?
  maskRatio   Float?   @map("mask_ratio")

  embedding   Unsupported("vector(512)")?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("clothing_items")
  @@index([userId])
  @@index([jobId])
}

// ==========================================
// 3. ClosetItem
// ==========================================
model ClosetItem {
  id           Int          @id @default(autoincrement())
  userId       Int          @map("user_id")
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  clothingItemId  Int?      @map("clothing_item_id")
  imageUrl        String?
  cropS3Key       String?   @map("crop_s3_key")

  // ── AI 자동 생성 이름 ──────────────────────────────────────
  // 저장 시점에 자동 생성: "Navy Zara Slim Jacket"
  // 생성 기준: colors + brand + fit + subCategory
  // 나중에 유저가 material/fit 추가 입력하면 name도 업데이트
  // LLM Response 노드에서 자연어 코디 설명 생성에 활용
  name         String?

  category     Category
  subCategory  SubCategory

  minTemp      Float?
  maxTemp      Float?

  isArchived   Boolean      @default(false)
  isWashing    Boolean      @default(false)

  embedding    Unsupported("vector(512)")?
  colors       String[]
  brand        String?
  memo         String?
  isFavorite   Boolean      @default(false) @map("is_favorite")
  wearCount    Int          @default(0)

  // ── 유저 추가 입력 필드 (팝업으로 수집) ─────────────────────
  // 옷 등록 후 팝업: "재질/핏을 추가하면 AI 추천이 더 정확해져요!"
  // 입력하면 name 자동 업데이트 + LLM 코디 설명 품질 향상

  material     String?
  // 재질: "cotton" | "wool" | "linen" | "polyester" | "denim" | "leather" | "knit" 등
  // 자유 입력 (enum 아님 — 재질은 너무 다양해서 enum으로 관리 어려움)

  fit          FitType?
  // 핏: SLIM | REGULAR | OVERSIZED | RELAXED
  // enum으로 관리 (선택지가 명확하기 때문)

  outfitItems  OutfitItem[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  season       Season?
  style        String?

  @@map("closet_items")
  @@index([userId])
  @@index([category, subCategory])
}

// ==========================================
// 4. StyleReference
// ==========================================
model StyleReference {
  id               Int          @id @default(autoincrement())
  userId           Int
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  type             StyleRefType

  presetKey        String?
  originalImageUrl String?
  rating           Int          @default(5)
  analysisResult   Json?
  embedding        Unsupported("vector(512)")?

  createdAt        DateTime     @default(now())
}

// ==========================================
// 5. ExternalItem (WishlistItem 대체)
// ==========================================
// 네이버 쇼핑 API에서 가져온 외부 아이템
// ⚠️ 이미지는 원본 URL 참조만 — S3에 저장하지 않음 (저작권)
model ExternalItem {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name         String
  brand        String?
  category     Category
  price        Int?
  currency     String   @default("KRW")

  imageUrl     String            // 원본 이미지 URL (S3 저장 X)
  purchaseUrl  String            // 구매 링크

  source       String   @default("naver_shopping")
  styleKeywords String[]

  outfitItems  OutfitItem[]

  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([source])
}

// ==========================================
// 6. Outfit (확장)
// ==========================================
model Outfit {
  id              Int          @id @default(autoincrement())
  userId          Int
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  title           String?
  imageUrl        String?

  recordedTemp    Float?
  recordedWeather String?

  source          OutfitSource @default(MANUAL)
  items           OutfitItem[]

  // AI 추천 히스토리 필드
  intent          String?
  recommendSource String?
  anchorItemId    Int?
  aiComment       String?
  conflictWarning String?
  feedback        String?      // "like" | "dislike" | null

  createdAt       DateTime     @default(now())

  @@index([userId])
  @@index([userId, source])
  @@index([userId, feedback])
}

// ==========================================
// 7. OutfitItem
// ==========================================
model OutfitItem {
  id              Int           @id @default(autoincrement())
  outfitId        Int
  outfit          Outfit        @relation(fields: [outfitId], references: [id], onDelete: Cascade)

  closetItemId    Int?
  closetItem      ClosetItem?   @relation(fields: [closetItemId], references: [id])

  externalItemId  Int?
  externalItem    ExternalItem? @relation(fields: [externalItemId], references: [id])

  position        String?
  isAnchor        Boolean       @default(false)
}

// ==========================================
// 8. Enums
// ==========================================
enum Gender {
  MALE
  FEMALE
  UNISEX
}

enum Category {
  TOP
  BOTTOM
  OUTER
  DRESS
  SHOES
  BAG
  ACC
}

enum SubCategory {
  T_SHIRT_SHORT
  T_SHIRT_LONG
  SHIRT
  KNIT
  SWEATSHIRT
  HOODIE
  VEST
  CARDIGAN
  WINDBREAKER
  JACKET
  COAT
  PADDED_LIGHT
  PADDED_HEAVY
  DENIM
  SLACKS
  COTTON_PANTS
  SWEATPANTS
  SHORTS
  SKIRT
}

enum FitType {
  SLIM
  REGULAR
  OVERSIZED
  RELAXED
}

enum Season {
  SPRING
  SUMMER
  FALL
  WINTER
  ALL
}

enum OutfitSource {
  MANUAL
  AI_SUGGEST
  CALENDAR
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum StyleRefType {
  PRESET
  CUSTOM
}
